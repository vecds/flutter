IMAGE:
STEP-1: create a folder in your project for IMAGE
        download and copy images into your folder
STEP-2: Update pubspec.yaml and assets init
        flutter:
        assets:
       - images/

Run flutter pub get after modifying pubspec.yaml.

main.dart

import 'package:flutter/material.dart';

void main() {
  runApp(const MyApp());
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      home: Scaffold(
        appBar: AppBar(
          title: const Text('Asset Image'),
        ),
        body: Center(
          child: Image.asset(
            'images/.jpg',
            width: 300,
            height: 300,
          ),
        ),
      ),
    );
  }
}




